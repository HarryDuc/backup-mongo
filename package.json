  "scripts": {
    "start": "node tools/cleaner-ui/server.js",
    "cleaner": "node tools/cleaner-ui/server.js",
    "clean:check": "npx -y find-duplicate-packages --no-delete",
    "clean:node_modules": "npx -y rimraf \"**/node_modules\" \"**/node_modules/**\"",
    "clean:dist": "npx -y rimraf \"**/dist\" \"**/dist/**\" \"**/*.dist\" \"**/*.dist/**\"",
    "clean:build": "npx -y rimraf \"**/build\" \"**/build/**\" \"**/*.build\" \"**/*.build/**\"",
    "clean:next": "npx -y rimraf \"**/.next\" \"**/.next/**\"",
    "clean:cache": "npx -y rimraf \"**/.cache\" \"**/.cache/**\" \"**/.gradle\" \"**/.gradle/**\"",
    "clean:all": "npm run clean:node_modules && npm run clean:dist && npm run clean:build && npm run clean:next && npm run clean:cache",
    "clean:report": "npx -y diskusage \"**/node_modules\" \"**/dist\" \"**/build\" \"**/.next\""
  }
}
